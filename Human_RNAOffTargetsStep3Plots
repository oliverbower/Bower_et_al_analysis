Create Figure Plots of observed SNVs in Control and Treated based on tsv.base_change_pct.txt and treated_vs_control_snps.txt files from Step2

```{r}
# Assign directories
# Ensure that .tsv files have columns annotated

input_dir <- "PathToOutputOfStep2"

files <- list.files(path = input_dir, pattern = ".tsv.base_change_pct.txt", full.names = TRUE)
filesCounts <- list.files(path = input_dir, pattern = "treated_vs_control_snps.txt", full.names = TRUE)


```

Merge all base change pct files for jitter plots
```{r}
# Extract group name from filename for column identity. For example
# lane8985_AACGTCTG_GCGTCATT_Sample_1_L001.tsv.base_change_pct.txt will become lane8985_AACGTCTG_GCGTCATT_Sample_1_L001

extract_group <- function(file) {
  basename(file) |>
    str_remove("^full_merged_") |>
    str_remove("\\.tsv\\.base_change_pct\\.txt$")
}

# Merge all .tsv.base_change_pct.txt files in directory for plotting
merged_df <- map_dfr(
  files,
  ~ read_tsv(.x, show_col_types = FALSE) |>
      mutate(group = extract_group(.x))
)
```

Jitter plot- All SNVs all sample pairs
```{r}
ggplot(merged_df, aes(x = full_condition, y = editing_pct, color = read_status)) +
  geom_jitter(
    width = 0.15,
    alpha = 0.5,
    size = 1.5
  ) +
  stat_summary(
    fun = mean,
    geom = "crossbar",
    width = 0.4,
    color = "red"
  ) +
  facet_wrap(vars(snv, group), nrow = 12, ncol = 8, scales = "fixed") +
  theme_classic() +
  theme(axis.text.x = element_text(angle=45))
  ylim(0,100)
```

Bar chart- Counts of all SNVs for all sample pairs
```{r}
extract_group2 <- function(file) {
  basename(file) |>
    str_remove("^full_merged_") |>
    str_remove("\\.tsv\\.treated_vs_control_snps\\.txt$")
}

# Merge all .tsv.base_change_pct.txt files in directory for plotting
merged_dfCounts <- map_dfr(
  filesCounts,
  ~ read_tsv(.x, show_col_types = FALSE) |>
      mutate(group = extract_group2(.x))
)

ggplot(merged_dfCounts) +
  geom_bar(aes(x = read_status, y = n, fill = read_status), stat = "identity") +
  facet_wrap(vars(snv, group), nrow = 12, ncol = 8) +
  theme_classic()
```

Testing SNVs in both Control and Treated where Control is 95% Wildtype (5%)
```{r}
