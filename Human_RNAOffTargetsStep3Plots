Filter out any common SNVs identified in both groups now that replicates have been added
```{r}
read_status_lookup <- merged_df %>%
  distinct(snv, poskey, condition) %>%
  group_by(snv, poskey) %>%
  summarise(
    read_status2 = case_when(
      all(condition == "ABE-treated") ~ "Treated_only",
      all(condition == "Control")     ~ "Control_only",
      any(condition == "ABE-treated") & any(condition == "Control") ~ "Both"
    ),
    .groups = "drop"
  )

merged_df <- merged_df %>%
  left_join(read_status_lookup, by = c("snv", "poskey"))

merged_df_exclusives_only <- merged_df %>%
  filter(!(read_status2 == "Both"))
```

Plot
```{r}
ggplot(merged_df_exclusives_only, aes(x = condition, y = editing_pct, color = read_status)) +
  geom_jitter(
    width = 0.15,
    alpha = 0.5,
    size = 1.5
  ) +
  stat_summary(
    fun = mean,
    geom = "crossbar",
    width = 0.4,
    color = "red"
  ) +
  facet_wrap(vars(snv), nrow = 4, ncol = 3, scales = "fixed") +
  theme_classic() +
  theme(axis.text.x = element_text(angle=45))
  ylim(0,100)
  
merged_df_exclusives_only_counts <- merged_df_exclusives_only %>%
  group_by(read_status2, snv, condition) %>%
  summarise(count = n(), mean = mean(editing_pct), sd = sd(editing_pct))

label_df <- merged_df_exclusives_only_counts %>%
  mutate(
    label = paste0("n = ", count),
    y_pos = 95   # fixed position near top; adjust if needed
  )



ggplot(
  merged_df_exclusives_only,
  aes(x = read_status2, y = editing_pct, color = read_status2)
) +
  geom_jitter(
    width = 0.15,
    alpha = 0.5,
    size = 1.5
  ) +
  ## Mean ± SD
  geom_errorbar(
    data = merged_df_exclusives_only_counts,
    aes(
      x = read_status2,
      y = mean,
      ymin = mean - sd,
      ymax = mean + sd
    ),
    width = 0.2,
    color = "black",
    linewidth = 0.6,
    inherit.aes = FALSE
  ) +
  geom_point(
    data = merged_df_exclusives_only_counts,
    aes(x = read_status2, y = mean),
    shape = 18,
    size = 3,
    color = "black",
    inherit.aes = FALSE
  ) +
  ## n labels
  geom_text(
    data = label_df,
    aes(
      x = read_status2,
      y = y_pos,
      label = label
    ),
    color = "black",
    size = 3,
    inherit.aes = FALSE
  ) +
  facet_wrap(vars(snv), nrow = 3, ncol = 4, scales = "fixed") +
  theme_classic() +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    legend.position = "top"
  ) +
  ylim(0, 100)


```


